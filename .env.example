# Supabase Configuration
# Copy this file to .env.local and fill in your actual values

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co

# Supabase Anonymous Key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Connection Strings
# Direct connection (port 5432) - use for migrations and admin tasks
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Pooler connection (port 6543) - use for application queries (recommended for serverless)
DATABASE_POOLER_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:6543/postgres

# Mapbox Configuration
# Get your token from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
# Optional: App will work without this, but email features will be disabled
RESEND_API_KEY=re_your_resend_api_key

# Email sender address for notifications
RESEND_FROM=LostStolenFound <noreply@yourdomain.com>

# Cron Job Security
# Generate a random secret for protecting cron endpoints
CRON_SECRET=your-random-secret-string

# Site Configuration
# Your production URL (used for email links and Open Graph)
NEXT_PUBLIC_SITE_URL=https://loststolenfound.vercel.app

# Admin Configuration
# Admin user email for elevated permissions (optional)
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# Google AdSense (optional)
# Get your publisher ID from https://www.google.com/adsense/
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
